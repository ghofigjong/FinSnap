{
  "name": "finsnap",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "packages/*"
  ],
  "scripts": {
    "mobile": "cd apps/mobile && npx expo start",
    "mobile:android": "cd apps/mobile && npx expo run:android",
    "api": "npm run dev --workspace=apps/api",
    "api:build": "npm run build --workspace=apps/api",
    "install:mobile": "cd apps/mobile && npm install",
    "install:all": "npm install && cd apps/mobile && npm install"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
